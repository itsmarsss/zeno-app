{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Zeno",
  "version": "0.1.0",
  "identifier": "com.zeno.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Zeno",
        "width": 336,
        "height": 492,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "backgroundColor": [0, 0, 0, 0],
        "visible": false,
        "alwaysOnTop": true
      },
      {
        "label": "main-window",
        "title": "Zeno",
        "create": false,
        "width": 860,
        "height": 620,
        "minWidth": 720,
        "minHeight": 520,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "trafficLightPosition": {
          "x": 10,
          "y": 16
        },
        "hiddenTitle": true,
        "resizable": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/henry.w@example.net",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "active": false,
      "pubkey": "REPLACE_WITH_MINISIGN_PUBKEY_BEFORE_ENABLING",
      "endpoints": ["https://github.com/[YOUR_USERNAME]/zeno/releases/latest/download/latest.json"]
    }
  }
}
