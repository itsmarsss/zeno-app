{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Zeno",
  "version": "0.1.0",
  "identifier": "com.zeno.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Zeno",
        "width": 320,
        "height": 480,
        "resizable": false,
        "decorations": false,
        "visible": false,
        "alwaysOnTop": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
